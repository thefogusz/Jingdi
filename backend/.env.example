# Copy this file to .env and fill in the values

# API Keys
GEMINI_API_KEYS=your_gemini_key1,your_gemini_key2
XAI_API_KEY=your_xai_key
ADMIN_PASSWORD=change_this_to_strong_password
FRONTEND_URL=https://jingdi.online

# PostgreSQL — Railway inject ให้อัตโนมัติ ไม่ต้องตั้งเอง (แต่ dev local ต้องตั้ง)
DATABASE_URL=postgresql://user:password@localhost:5432/jingdi

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=jingdi-uploads
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev
